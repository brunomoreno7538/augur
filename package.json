{
  "name": "augur",
  "version": "0.1.0",
  "description": "An interpreted language whose operations are divined by an LLM instead of computed",
  "type": "module",
  "bin": {
    "aug": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "bun build src/index.ts --compile --outfile aug"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "commander": "^15.0.0",
    "ollama": "^0.6.3",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
