{
  "name": "augur",
  "version": "1.0.0",
  "description": "An interpreted language whose operations are divined by an LLM instead of computed",
  "type": "module",
  "license": "MIT",
  "keywords": ["llm", "ai", "language", "interpreter", "bun", "meme", "dsl"],
  "homepage": "https://github.com/brunomoreno7538/augur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brunomoreno7538/augur.git"
  },
  "bin": {
    "aug": "./src/index.ts"
  },
  "files": ["src", "examples", "docs", "README.md", "LICENSE"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "bun build src/index.ts --compile --outfile aug"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "commander": "^15.0.0",
    "ollama": "^0.6.3",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
